# =====================================================================
# Container runtime settings (consumed by the Go binary)
# =====================================================================

# Path INSIDE the container where CCTV footage is mounted (read-only).
CCTV_ARCHIVE_PATH=/cctv

# Path INSIDE the container where the SQLite database file lives.
# Must reside on a persisted volume.
DB_PATH=/data/cctv.db

# Port the API listens on inside the container.
API_PORT=8080

# Allowed CORS origin for local development (e.g. http://localhost:5173).
# Leave EMPTY in production — the Go server will then serve the SPA from
# the same origin and CORS is unnecessary.
CORS_ALLOWED_ORIGIN=

# Where the compiled SPA lives. Defaults to /app/web (Docker layout).
# For native local dev, override to ./frontend/build.
# STATIC_PATH=./frontend/build

# =====================================================================
# Host-side settings (consumed by docker-compose for volume mapping)
# =====================================================================

# Absolute path on the NAS where the .mp4 files are written.
HOST_CCTV_PATH=/srv/cctv

# Path on the NAS where the SQLite DB will be persisted.
# Can be relative to docker-compose.yml or absolute.
HOST_DATA_PATH=./data

# Host port to publish the dashboard on.
HOST_PORT=8080
